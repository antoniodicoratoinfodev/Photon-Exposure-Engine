<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:scrollbars="none"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ══════════════════════════════════════════════════════════════
             INTESTAZIONE CON BACK
        ═══════════════════════════════════════════════════════════════ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="start|center_vertical"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/back_content_desc"
                android:src="@drawable/ic_arrow_back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/formulas_page_title"
                android:textColor="@color/text_primary"
                android:textSize="17sp"
                android:textStyle="bold"
                android:letterSpacing="0.02" />

        </FrameLayout>

        <View
            android:layout_width="36dp"
            android:layout_height="3dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_accent_bar" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:paddingBottom="20dp"
            android:text="@string/formulas_page_subtitle"
            android:textAllCaps="true"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.25" />

        <!-- 1 — Lux → EV -->
        <com.google.android.material.card.MaterialCardView style="@style/Widget.App.FormulaCard">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/Widget.App.FormulaSectionTitle"
                    android:text="@string/formula_s1_title" />

                <TextView
                    style="@style/Widget.App.FormulaCode"
                    android:text="@string/formula_s1_code" />

                <TextView
                    style="@style/Widget.App.FormulaBody"
                    android:text="@string/formula_s1_desc" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 2 — Correzione ISO -->
        <com.google.android.material.card.MaterialCardView style="@style/Widget.App.FormulaCard">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/Widget.App.FormulaSectionTitle"
                    android:text="@string/formula_s2_title" />

                <TextView
                    style="@style/Widget.App.FormulaCode"
                    android:text="@string/formula_s2_code" />

                <TextView
                    style="@style/Widget.App.FormulaBody"
                    android:text="@string/formula_s2_desc" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 3 — EV dalla triade -->
        <com.google.android.material.card.MaterialCardView style="@style/Widget.App.FormulaCard">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/Widget.App.FormulaSectionTitle"
                    android:text="@string/formula_s3_title" />

                <TextView
                    style="@style/Widget.App.FormulaCode"
                    android:text="@string/formula_s3_code" />

                <TextView
                    style="@style/Widget.App.FormulaBody"
                    android:text="@string/formula_s3_desc" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 4 — Quantità derivate -->
        <com.google.android.material.card.MaterialCardView style="@style/Widget.App.FormulaCard">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/Widget.App.FormulaSectionTitle"
                    android:text="@string/formula_s4_title" />

                <TextView
                    style="@style/Widget.App.FormulaCode"
                    android:text="@string/formula_s4_code" />

                <TextView
                    style="@style/Widget.App.FormulaBody"
                    android:text="@string/formula_s4_desc" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 5 — Validazione incrociata -->
        <com.google.android.material.card.MaterialCardView style="@style/Widget.App.FormulaCard">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/Widget.App.FormulaSectionTitle"
                    android:text="@string/formula_s5_title" />

                <TextView
                    style="@style/Widget.App.FormulaCode"
                    android:text="@string/formula_s5_code" />

                <TextView
                    style="@style/Widget.App.FormulaBody"
                    android:text="@string/formula_s5_desc" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Note di calibrazione -->
        <com.google.android.material.card.MaterialCardView style="@style/Widget.App.FormulaCard">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/Widget.App.FormulaSectionTitle"
                    android:text="@string/formula_notes_title"
                    android:textColor="@color/accent_orange" />

                <TextView
                    style="@style/Widget.App.FormulaBody"
                    android:paddingTop="0dp"
                    android:text="@string/formula_notes_desc" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Fonti -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.App.FormulaCard"
            android:layout_marginBottom="24dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/Widget.App.FormulaSectionTitle"
                    android:text="@string/formula_sources_title"
                    android:textColor="@color/accent_gold" />

                <TextView
                    style="@style/Widget.App.FormulaBody"
                    android:paddingTop="0dp"
                    android:text="@string/formula_sources_desc" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
