<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:scrollbars="none"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ══════════════════════════════════════════════════════════════
             INTESTAZIONE
        ═══════════════════════════════════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingTop="8dp"
            android:text="@string/app_name"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <View
            android:layout_width="36dp"
            android:layout_height="3dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_accent_bar" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:paddingBottom="20dp"
            android:text="@string/subtitle"
            android:textAllCaps="true"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.25" />

        <!-- ══════════════════════════════════════════════════════════════
             CARD: INPUT LUX
        ═══════════════════════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingBottom="10dp"
                    android:text="@string/label_lux_input"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.03" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:hintEnabled="false"
                    app:boxBackgroundColor="@color/field_bg"
                    app:boxStrokeColor="@color/accent_blue"
                    app:boxStrokeWidth="1dp"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    app:suffixText="@string/lux_unit"
                    app:suffixTextColor="@color/text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etLux"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/hint_lux"
                        android:inputType="numberDecimal"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="17sp"
                        android:autofillHints="number" />

                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/lux_formula_note"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:paddingTop="10dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════════════════════════════════════════════════════
             CARD: ISO
        ═══════════════════════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingBottom="10dp"
                    android:text="@string/label_iso"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.03" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_field"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="4dp">

                    <Spinner
                        android:id="@+id/spinnerISO"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:backgroundTint="@color/accent_blue_light"
                        android:popupBackground="@color/card_bg" />

                </FrameLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════════════════════════════════════════════════════
             CARD: MODALITÀ A — Fisso il diaframma
        ═══════════════════════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mode_a_title"
                    android:textColor="@color/accent_blue_light"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.03"
                    android:paddingBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mode_a_desc"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:paddingBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_fstop"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:paddingBottom="6dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/bg_field"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="4dp">

                    <Spinner
                        android:id="@+id/spinnerFStop"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:backgroundTint="@color/accent_blue_light"
                        android:popupBackground="@color/card_bg" />

                </FrameLayout>

                <Button
                    android:id="@+id/btnCalcFromFStop"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/accent_blue"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:text="@string/btn_calc_fstop"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    app:cornerRadius="12dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════════════════════════════════════════════════════
             CARD: MODALITÀ B — Fisso il tempo
        ═══════════════════════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mode_b_title"
                    android:textColor="@color/accent_orange"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.03"
                    android:paddingBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mode_b_desc"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:paddingBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_shutter"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:paddingBottom="6dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/bg_field"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="4dp">

                    <Spinner
                        android:id="@+id/spinnerShutter"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:backgroundTint="@color/accent_orange"
                        android:popupBackground="@color/card_bg" />

                </FrameLayout>

                <Button
                    android:id="@+id/btnCalcFromShutter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/accent_orange"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:text="@string/btn_calc_shutter"
                    android:textColor="@color/on_accent_orange"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    app:cornerRadius="12dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════════════════════════════════════════════════════
             CARD: RISULTATI
        ═══════════════════════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="@color/card_result_bg"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/result_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingBottom="14dp"
                    android:text="@string/results_title"
                    android:textAllCaps="true"
                    android:textColor="@color/accent_gold"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12" />

                <TextView
                    android:id="@+id/tvEV100"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/placeholder_ev100"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:paddingBottom="6dp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tvEVISO"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/placeholder_ev_iso"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:paddingBottom="6dp"
                    android:fontFamily="monospace" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/tvFNumber"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/placeholder_fnumber"
                    android:textColor="@color/accent_blue_light"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:paddingBottom="8dp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tvShutterSpeed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/placeholder_shutter"
                    android:textColor="@color/accent_orange"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:paddingBottom="4dp"
                    android:fontFamily="monospace" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/tvSceneDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/placeholder_scene"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:textStyle="italic" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════════════════════════════════════════════════════
             CARD: COMBINAZIONI EQUIVALENTI
        ═══════════════════════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:id="@+id/tvEquivalentsHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="10dp"
                    android:text="@string/equivalents_title"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.03" />

                <LinearLayout
                    android:id="@+id/layoutEquivalents"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════════════════════════════════════════════════════
             BOTTONE: MATH & FORMULAS REFERENCE
        ═══════════════════════════════════════════════════════════════ -->
        <Button
            android:id="@+id/btnFormulas"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:text="@string/btn_formulas"
            android:textColor="@color/accent_gold"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            app:cornerRadius="12dp"
            app:rippleColor="@color/result_stroke"
            app:strokeColor="@color/accent_gold"
            app:strokeWidth="1dp" />

    </LinearLayout>
</ScrollView>
