<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.LuxExposimeter" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorPrimaryVariant">@color/accent_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_gold</item>
        <item name="colorSecondaryVariant">@color/accent_gold</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSurface">@color/card_bg</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorControlActivated">@color/accent_blue_light</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:colorBackground">@color/bg_dark</item>
    </style>

    <!-- Stili riusabili per la pagina Math & Formulas Reference -->
    <style name="Widget.App.FormulaCard" parent="Widget.MaterialComponents.CardView">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">14dp</item>
        <item name="cardBackgroundColor">@color/card_bg</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/card_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.App.FormulaSectionTitle" parent="">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/accent_blue_light</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.03</item>
        <item name="android:paddingBottom">10dp</item>
    </style>

    <style name="Widget.App.FormulaCode" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/bg_field</item>
        <item name="android:padding">12dp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textColor">@color/accent_gold</item>
        <item name="android:textSize">13sp</item>
        <item name="android:lineSpacingMultiplier">1.3</item>
    </style>

    <style name="Widget.App.FormulaBody" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:lineSpacingMultiplier">1.35</item>
    </style>
</resources>
