    <!-- Formule -->
    <string name="formula_title">Mathematical formulas reference</string>
    <string name="formula_content">
EV₁₀₀ = log₂(E / 2.5)

E = illuminance in lux
C = 250 (ANSI/ISO constant, flat sensor)

EV_ISO = EV₁₀₀ + log₂(ISO / 100)

EV = log₂(N² / t)

N = f-number (aperture)
t = exposure time (seconds)

Given EV and N: t = N² / 2^EV
Given EV and t: N = √(t × 2^EV)

Source: Wikipedia "Exposure value",
ANSI PH3.49-1971, ISO 2720:1974
    </string>
